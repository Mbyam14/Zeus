# Zeus Backend Environment Variables
# Copy this file to .env and fill in your actual values

# --- REQUIRED ---

# Environment: development, staging, production
ENVIRONMENT=development

# JWT Secret (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your_secret_key_here

# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=your_anthropic_api_key

# CORS - comma-separated origins
# Development: add your local IP
ALLOWED_ORIGINS=http://localhost:19006,http://192.168.0.16:8081

# --- OPTIONAL ---

# AWS S3 (for recipe image uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# Instacart integration
INSTACART_API_KEY=
INSTACART_WEBHOOK_SECRET=

# Sentry error tracking
SENTRY_DSN=

# Rate limiting (requests per minute)
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AI=10/minute
RATE_LIMIT_AUTH=5/minute

# JWT token expiration
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Request size limit
MAX_REQUEST_SIZE_MB=10
